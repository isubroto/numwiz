{
  "name": "numwiz",
  "version": "1.2.0",
  "description": "The ultimate number utility — arithmetic, formatting, currency (Lakh/Crore & Million/Billion), number-to-words in 10+ languages, statistics, financial math & more.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./arithmetic": {
      "types": "./dist/src/arithmetic.d.ts",
      "import": "./dist/src/arithmetic.mjs",
      "require": "./dist/src/arithmetic.js",
      "default": "./dist/src/arithmetic.mjs"
    },
    "./comparison": {
      "types": "./dist/src/comparison.d.ts",
      "import": "./dist/src/comparison.mjs",
      "require": "./dist/src/comparison.js",
      "default": "./dist/src/comparison.mjs"
    },
    "./validation": {
      "types": "./dist/src/validation.d.ts",
      "import": "./dist/src/validation.mjs",
      "require": "./dist/src/validation.js",
      "default": "./dist/src/validation.mjs"
    },
    "./conversion": {
      "types": "./dist/src/conversion.d.ts",
      "import": "./dist/src/conversion.mjs",
      "require": "./dist/src/conversion.js",
      "default": "./dist/src/conversion.mjs"
    },
    "./bitwise": {
      "types": "./dist/src/bitwise.d.ts",
      "import": "./dist/src/bitwise.mjs",
      "require": "./dist/src/bitwise.js",
      "default": "./dist/src/bitwise.mjs"
    },
    "./trigonometry": {
      "types": "./dist/src/trigonometry.d.ts",
      "import": "./dist/src/trigonometry.mjs",
      "require": "./dist/src/trigonometry.js",
      "default": "./dist/src/trigonometry.mjs"
    },
    "./range": {
      "types": "./dist/src/range.d.ts",
      "import": "./dist/src/range.mjs",
      "require": "./dist/src/range.js",
      "default": "./dist/src/range.mjs"
    },
    "./statistics": {
      "types": "./dist/src/statistics.d.ts",
      "import": "./dist/src/statistics.mjs",
      "require": "./dist/src/statistics.js",
      "default": "./dist/src/statistics.mjs"
    },
    "./financial": {
      "types": "./dist/src/financial.d.ts",
      "import": "./dist/src/financial.mjs",
      "require": "./dist/src/financial.js",
      "default": "./dist/src/financial.mjs"
    },
    "./sequences": {
      "types": "./dist/src/sequences.d.ts",
      "import": "./dist/src/sequences.mjs",
      "require": "./dist/src/sequences.js",
      "default": "./dist/src/sequences.mjs"
    },
    "./random": {
      "types": "./dist/src/random.d.ts",
      "import": "./dist/src/random.mjs",
      "require": "./dist/src/random.js",
      "default": "./dist/src/random.mjs"
    },
    "./advanced": {
      "types": "./dist/src/advanced.d.ts",
      "import": "./dist/src/advanced.mjs",
      "require": "./dist/src/advanced.js",
      "default": "./dist/src/advanced.mjs"
    },
    "./formatting": {
      "types": "./dist/src/formatting.d.ts",
      "import": "./dist/src/formatting.mjs",
      "require": "./dist/src/formatting.js",
      "default": "./dist/src/formatting.mjs"
    },
    "./currency": {
      "types": "./dist/src/currency.d.ts",
      "import": "./dist/src/currency.mjs",
      "require": "./dist/src/currency.js",
      "default": "./dist/src/currency.mjs"
    },
    "./matrix": {
      "types": "./dist/src/matrix.d.ts",
      "import": "./dist/src/matrix.mjs",
      "require": "./dist/src/matrix.js",
      "default": "./dist/src/matrix.mjs"
    },
    "./number-words": {
      "types": "./dist/src/number-words.d.ts",
      "import": "./dist/src/number-words.mjs",
      "require": "./dist/src/number-words.js",
      "default": "./dist/src/number-words.mjs"
    },
    "./types": {
      "types": "./dist/src/types.d.ts",
      "import": "./dist/src/types.mjs",
      "require": "./dist/src/types.js",
      "default": "./dist/src/types.mjs"
    },
    "./ndarray": {
      "types": "./dist/src/ndarray.d.ts",
      "import": "./dist/src/ndarray.mjs",
      "require": "./dist/src/ndarray.js",
      "default": "./dist/src/ndarray.mjs"
    },
    "./linalg": {
      "types": "./dist/src/linalg.d.ts",
