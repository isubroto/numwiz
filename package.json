      "require": "./dist/src/linalg.js",
      "default": "./dist/src/linalg.mjs"
    },
    "./polynomial": {
      "types": "./dist/src/polynomial.d.ts",
      "import": "./dist/src/polynomial.mjs",
      "require": "./dist/src/polynomial.js",
      "default": "./dist/src/polynomial.mjs"
    },
    "./calculus": {
      "types": "./dist/src/calculus.d.ts",
      "import": "./dist/src/calculus.mjs",
      "require": "./dist/src/calculus.js",
      "default": "./dist/src/calculus.mjs"
    },
    "./fft": {
      "types": "./dist/src/fft.d.ts",
      "import": "./dist/src/fft.mjs",
      "require": "./dist/src/fft.js",
      "default": "./dist/src/fft.mjs"
    },
    "./interpolation": {
      "types": "./dist/src/interpolation.d.ts",
      "import": "./dist/src/interpolation.mjs",
      "require": "./dist/src/interpolation.js",
      "default": "./dist/src/interpolation.mjs"
    },
    "./signal": {
      "types": "./dist/src/signal.d.ts",
      "import": "./dist/src/signal.mjs",
      "require": "./dist/src/signal.js",
      "default": "./dist/src/signal.mjs"
    },
    "./precision": {
      "types": "./dist/src/precision.d.ts",
      "import": "./dist/src/precision.mjs",
      "require": "./dist/src/precision.js",
      "default": "./dist/src/precision.mjs"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "scripts": {
    "clean": "npx rimraf dist",
    "prebuild": "npm run clean",
    "build": "tsc",
    "postbuild": "node scripts/generate-esm-wrappers.cjs",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/lint.cjs",
    "format": "node scripts/format-check.cjs",
    "test": "jest --runInBand",
    "coverage": "jest --coverage --runInBand",
    "test:coverage": "npm run coverage",
    "bench": "npm run build && node --expose-gc benchmark/native-vs-numwiz.js",
    "benchmark": "npm run bench",
    "package:validate": "node scripts/validate-package.cjs",
    "release:validate": "npm run build && npm test && npm run package:validate && npm run bench",
    "ci": "npm run lint && npm run typecheck && npm test && npm run coverage && npm run build && npm run package:validate"
  },
  "keywords": [
    "number",
    "math",
    "currency",
    "lakh",
    "crore",
    "million",
    "billion",
    "number-to-words",
    "hindi",
    "i18n",
    "statistics",
    "formatting",
    "utility",
    "typescript",
    "numpy",
    "ndarray",
    "fft",
    "interpolation",
    "linear-algebra",
    "polynomial",
    "signal-processing",
    "calculus",
    "scientific-computing"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isubroto/numwiz.git"
  },
  "bugs": {
    "url": "https://github.com/isubroto/numwiz/issues"
  },
  "homepage": "https://github.com/isubroto/numwiz#readme",
  "author": "Subroto Saha",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  },
  "dependencies": {
    "decimal.js": "^10.6.0"
  }
}
