{
  "name": "numwiz",
  "version": "1.1.1",
  "description": "The ultimate number utility — arithmetic, formatting, currency (Lakh/Crore & Million/Billion), number-to-words in 10+ languages, statistics, financial math & more.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./arithmetic": {
      "require": "./dist/src/arithmetic.js",
      "types": "./dist/src/arithmetic.d.ts"
    },
    "./comparison": {
      "require": "./dist/src/comparison.js",
      "types": "./dist/src/comparison.d.ts"
    },
    "./validation": {
      "require": "./dist/src/validation.js",
      "types": "./dist/src/validation.d.ts"
    },
    "./conversion": {
      "require": "./dist/src/conversion.js",
      "types": "./dist/src/conversion.d.ts"
    },
    "./bitwise": {
      "require": "./dist/src/bitwise.js",
      "types": "./dist/src/bitwise.d.ts"
    },
    "./trigonometry": {
      "require": "./dist/src/trigonometry.js",
      "types": "./dist/src/trigonometry.d.ts"
    },
    "./range": {
      "require": "./dist/src/range.js",
      "types": "./dist/src/range.d.ts"
    },
    "./statistics": {
      "require": "./dist/src/statistics.js",
      "types": "./dist/src/statistics.d.ts"
    },
    "./financial": {
      "require": "./dist/src/financial.js",
      "types": "./dist/src/financial.d.ts"
    },
    "./sequences": {
      "require": "./dist/src/sequences.js",
      "types": "./dist/src/sequences.d.ts"
    },
    "./random": {
      "require": "./dist/src/random.js",
      "types": "./dist/src/random.d.ts"
    },
    "./advanced": {
      "require": "./dist/src/advanced.js",
      "types": "./dist/src/advanced.d.ts"
    },
    "./formatting": {
      "require": "./dist/src/formatting.js",
      "types": "./dist/src/formatting.d.ts"
    },
    "./currency": {
      "require": "./dist/src/currency.js",
      "types": "./dist/src/currency.d.ts"
    },
    "./matrix": {
      "require": "./dist/src/matrix.js",
      "types": "./dist/src/matrix.d.ts"
    },
    "./number-words": {
      "require": "./dist/src/number-words.js",
      "types": "./dist/src/number-words.d.ts"
    },
    "./types": {
      "types": "./dist/src/types.d.ts"
    },
    "./ndarray": {
      "require": "./dist/src/ndarray.js",
      "types": "./dist/src/ndarray.d.ts"
    },
    "./linalg": {
      "require": "./dist/src/linalg.js",
      "types": "./dist/src/linalg.d.ts"
    },
    "./polynomial": {
      "require": "./dist/src/polynomial.js",
      "types": "./dist/src/polynomial.d.ts"
    },
    "./calculus": {
      "require": "./dist/src/calculus.js",
      "types": "./dist/src/calculus.d.ts"
    },
    "./fft": {
      "require": "./dist/src/fft.js",
      "types": "./dist/src/fft.d.ts"
    },
    "./interpolation": {
      "require": "./dist/src/interpolation.js",
      "types": "./dist/src/interpolation.d.ts"
    },
    "./signal": {
      "require": "./dist/src/signal.js",
      "types": "./dist/src/signal.d.ts"
    },
    "./precision": {
      "require": "./dist/src/precision.js",
      "types": "./dist/src/precision.d.ts"
    }
  },
  "scripts": {
    "clean": "npx rimraf dist",
    "prebuild": "npm run clean",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest --verbose",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "number",
    "math",
    "currency",
    "lakh",
    "crore",
    "million",
    "billion",
    "number-to-words",
    "hindi",
    "i18n",
    "statistics",
    "formatting",
    "utility",
    "typescript",
    "numpy",
    "ndarray",
    "fft",
    "interpolation",
    "linear-algebra",
    "polynomial",
    "signal-processing",
    "calculus",
    "scientific-computing"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Subroto Saha",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  },
  "dependencies": {
    "decimal.js": "^10.6.0"
  }
}
